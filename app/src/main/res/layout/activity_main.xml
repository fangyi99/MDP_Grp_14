<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_system"
    android:fitsSystemWindows="true">

    <!-- INFORMATIONAL DISPLAYS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:paddingTop="14dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_pill_violet"
            android:elevation="2dp"
            android:padding="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_label"
                android:textSize="8sp"
                android:textColor="@color/ink_soft"
                android:letterSpacing="0.05"
                android:textAllCaps="true"/>

            <TextView
                android:id="@+id/robotStatusTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IDLE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp"
                android:textColor="@color/violet_dark"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_pill_violet"
            android:elevation="2dp"
            android:padding="6dp">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/position_label"
                android:textSize="8sp"
                android:textColor="@color/ink_soft"
                android:letterSpacing="0.05"
                android:textAllCaps="true"/>

            <TextView
                android:id="@+id/positionTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="11sp"
                android:textColor="@color/violet_dark"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_pill_violet"
            android:elevation="2dp"
            android:padding="6dp">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/direction_label"
                android:textSize="8sp"
                android:textColor="@color/ink_soft"
                android:letterSpacing="0.05"
                android:textAllCaps="true"/>

            <TextView
                android:id="@+id/directionTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="@color/violet_dark"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_pill_violet"
            android:elevation="2dp"
            android:padding="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/timer_label"
                android:textSize="8sp"
                android:textColor="@color/ink_soft"
                android:letterSpacing="0.05"
                android:textAllCaps="true"/>

            <TextView
                android:id="@+id/timerTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textSize="11sp"
                android:textColor="@color/violet_dark"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- MAP + SHORTCUTS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- Map Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Lock Toggle and Robot Button Row -->
            <LinearLayout
                android:id="@+id/lockPill"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/bg_action_blank"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="12dp">

                <ToggleButton
                    android:id="@+id/lockToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:checked="false"
                    android:textColor="@color/gold_dark"
                    android:textOff="@string/lock_unlocked"
                    android:textOn="@string/lock_locked"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/spawnRobotButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/btn_robot"
                android:textSize="12sp"
                android:textColor="@color/bg_card"
                android:textStyle="bold"
                android:background="@drawable/bg_action_black"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:elevation="2dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>

            <!-- Arena Map View -->

            <com.example.mdp_14.ArenaMapView
                android:id="@+id/arenaMapView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_lg"
                android:elevation="2dp"/>

            <!-- GROUPED CONTROLS SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="7dp">

                    <TextView
                        android:layout_width="45dp"
                        android:layout_height="wrap_content"
                        android:text="@string/map_label"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="@color/ink_soft"
                        android:layout_marginEnd="4dp"/>

                    <Button
                        android:id="@+id/addObstacleButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:text="@string/btn_add"
                        android:textSize="11sp"
                        android:textColor="@color/sky"
                        android:textStyle="bold"
                        android:background="@drawable/bg_map_sky"
                        android:elevation="1dp"
                        android:stateListAnimator="@null"/>

                    <Button
                        android:id="@+id/editObstacleButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:text="@string/btn_edit"
                        android:textSize="11sp"
                        android:textColor="@color/sky"
                        android:background="@drawable/bg_map_sky"
                        android:elevation="1dp"
                        android:stateListAnimator="@null"/>

                    <Button
                        android:id="@+id/deleteObstacleButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:text="@string/btn_delete"
                        android:textSize="11sp"
                        android:textColor="@color/coral"
                        android:background="@drawable/bg_map_coral"
                        android:elevation="1dp"
                        android:stateListAnimator="@null"/>

                    <Button
                        android:id="@+id/clearAllButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:text="@string/btn_clear"
                        android:textSize="11sp"
                        android:textColor="@color/coral"
                        android:background="@drawable/bg_map_coral"
                        android:elevation="1dp"
                        android:stateListAnimator="@null"/>
                </LinearLayout>

                <!-- ACTIONS Group -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:text="@string/action_label"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="@color/ink_soft"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>

                    <Button
                        android:id="@+id/sendObstaclesButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="@string/btn_send"
                        android:textSize="11sp"
                        android:textColor="@color/bg_card"
                        android:textStyle="bold"
                        android:background="@drawable/bg_action_black"
                        android:elevation="2dp"
                        android:stateListAnimator="@null"/>

                    <Button
                        android:id="@+id/exploreButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="@string/btn_explore"
                        android:textSize="11sp"
                        android:textColor="@color/mint"
                        android:textStyle="bold"
                        android:background="@drawable/bg_action_mint"
                        android:stateListAnimator="@null"/>

                    <Button
                        android:id="@+id/fastestPathButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:text="@string/btn_fastest"
                        android:layout_marginEnd="6dp"
                        android:textSize="11sp"
                        android:textColor="@color/mint"
                        android:textStyle="bold"
                        android:background="@drawable/bg_action_mint"
                        android:stateListAnimator="@null"/>

                    <Button
                        android:id="@+id/stopButton"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:text="Reset"
                        android:textSize="11sp"
                        android:textColor="@color/coral"
                        android:background="@drawable/bg_map_coral"
                        android:elevation="1dp"
                        android:stateListAnimator="@null"/>

                </LinearLayout>
            </LinearLayout>

    <!-- Messages & Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_system"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp"
        android:elevation="4dp">

        <!-- Messages + Input -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/msg_log_title"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/ink"/>

                <Button
                    android:id="@+id/clearMessagesBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:text="@string/msg_clear"
                    android:textSize="11sp"
                    android:textColor="@color/sky"
                    android:background="@null"
                    android:padding="0dp"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <!-- Messages ScrollView -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/bg_card_lg"
                android:padding="8dp"
                android:elevation="1dp">

                <TextView
                    android:id="@+id/receivedText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Waiting for ..."
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/ink_mid"
                    android:lineSpacingMultiplier="1.4"/>
            </ScrollView>

            <!-- Message Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_lg"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="5dp"
                android:layout_marginTop="7dp"
                android:elevation="1dp">

                <EditText
                    android:id="@+id/messageInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Message…"
                    android:inputType="text"
                    android:textSize="12sp"
                    android:textColor="@color/ink"
                    android:background="@null"/>

                <ImageButton
                    android:id="@+id/sendBtn"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@android:drawable/ic_menu_send"
                    android:background="@drawable/bg_send_btn"
                    android:enabled="false"
                    android:padding="18dp"
                    android:contentDescription="Send"
                    app:tint="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Control Pad -->
        <LinearLayout
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Tilt Control -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tilt_label"
                    android:textSize="10sp"
                    android:textColor="@color/ink_mid"
                    android:layout_marginEnd="4dp"/>

                <Switch
                    android:id="@+id/tiltControlSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- D-Pad -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_marginBottom="4dp">
                <Button
                    android:id="@+id/upBtn"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="↑"
                    android:textSize="22sp"
                    android:textColor="@color/ink"
                    android:background="@drawable/bg_dpad"
                    android:enabled="false"
                    android:elevation="1dp"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="3dp"/>
            </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_horizontal">

                    <Button
                        android:id="@+id/leftBtn"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:text="←"
                        android:textSize="22sp"
                        android:textColor="@color/ink"
                        android:background="@drawable/bg_dpad"
                        android:enabled="false"
                        android:elevation="1dp"
                        android:stateListAnimator="@null"
                        android:layout_marginEnd="3dp"/>

                    <Button
                        android:id="@+id/downBtn"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:text="↓"
                        android:textSize="22sp"
                        android:textColor="@color/ink"
                        android:background="@drawable/bg_dpad"
                        android:enabled="false"
                        android:elevation="1dp"
                        android:stateListAnimator="@null"
                        android:layout_marginEnd="3dp"/>

                    <Button
                        android:id="@+id/rightBtn"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:text="→"
                        android:textSize="22sp"
                        android:textColor="@color/ink"
                        android:background="@drawable/bg_dpad"
                        android:enabled="false"
                        android:elevation="1dp"
                        android:stateListAnimator="@null"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>